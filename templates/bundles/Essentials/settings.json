{
  "diffEditor.codeLens": true,
  "editor.acceptSuggestionOnEnter": "smart",
  "editor.accessibilityPageSize": 20,
  "editor.accessibilitySupport": "off",
  "editor.autoClosingDelete": "never",
  "editor.detectIndentation": false,
  "editor.dragAndDrop": false,
  "editor.fastScrollSensitivity": 100,
  "editor.formatOnSave": true,
  "editor.indentSize": "tabSize",
  "editor.inlayHints.enabled": "off",
  "editor.inlineSuggest.enabled": true,
  "editor.linkedEditing": true,
  "editor.mouseWheelZoom": true,
  "editor.multiCursorPaste": "full",
  "editor.suggest.preview": true,
  "editor.suggestSelection": "recentlyUsedByPrefix",
  "editor.tabCompletion": "on",
  "editor.unicodeHighlight.includeComments": true,
  "editor.unicodeHighlight.nonBasicASCII": true,
  "errorLens.codeLensOnClick": "showProblemsView",
  "errorLens.codeLensTemplate": "$severity - ($message)",
  "explorer.compactFolders": false,
  "explorer.confirmDelete": false,
  "explorer.confirmDragAndDrop": false,
  "explorer.confirmPasteNative": false,
  "explorer.confirmUndo": "verbose",
  "explorer.incrementalNaming": "smart",
  "files.associations": {
    ".env*": "dotenv"
  },
  "files.autoSave": "onFocusChange",
  "files.autoSaveDelay": 60000,
  "files.eol": "\n",
  "files.insertFinalNewline": true,
  "files.trimFinalNewlines": true,
  "files.trimTrailingWhitespace": true,
  "search.quickOpen.history.filterSortOrder": "recency",
  "search.smartCase": true,
  "security.workspace.trust.untrustedFiles": "open",
  "task.allowAutomaticTasks": "on",
  "task.problemMatchers.neverPrompt": {
    "shell": true
  },
  "telemetry.telemetryLevel": "off",
  "terminal.integrated.allowedLinkSchemes": [
    "file",
    "http",
    "https",
    "mailto",
    "vscode",
    "vscode-insiders",
    "docker-desktop"
  ],
  "terminal.integrated.confirmOnExit": "hasChildProcesses",
  "terminal.integrated.cursorBlinking": true,
  "terminal.integrated.defaultProfile.windows": "Command Prompt",
  "terminal.integrated.enableMultiLinePasteWarning": false,
  "terminal.integrated.enablePersistentSessions": false,
  "workbench.commandPalette.experimental.suggestCommands": true,
  "workbench.commandPalette.history": 10,
  "workbench.editor.defaultBinaryEditor": "default",
  "workbench.hover.delay": 1000,
  "workbench.startupEditor": "none",
  "workbench.tips.enabled": false
}
